rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Times ────────────────────────────────────────────────────────────────
    // Leitura pública; escrita restrita a admins autenticados
    match /times/{timeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Rodadas ──────────────────────────────────────────────────────────────
    // Leitura pública; escrita restrita a admins autenticados
    match /rodadas2026_fase1/{rodadaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rodadas2026_fase2/{rodadaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /rodadas2026_final/{rodadaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Configurações ────────────────────────────────────────────────────────
    // Leitura pública; escrita restrita a admins autenticados
    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Tokens FCM (Android/Chrome) ──────────────────────────────────────────
    // Ninguém lê; qualquer cliente autenticado registra apenas o próprio token.
    // Validações:
    //   - deve ter o campo "token" (string não vazia)
    //   - tamanho máximo razoável para evitar payloads abusivos
    match /fcmTokens/{tokenId} {
      allow read:   if false;
      allow delete: if false;

      allow create, update: if
        // Deve ter o campo obrigatório "token"
        request.resource.data.keys().hasAll(['token']) &&
        // token deve ser string não vazia
        request.resource.data.token is string &&
        request.resource.data.token.size() > 0 &&
        request.resource.data.token.size() <= 4096 &&
        // Documento não pode ter mais de 10 campos (evita payload inflado)
        request.resource.data.keys().size() <= 10;
    }

    // ── Web Push Subscriptions (iOS + Android PWA) ───────────────────────────
    // Ninguém lê; qualquer cliente registra sua subscription.
    // Validações:
    //   - deve ter o campo "endpoint" (string, URL válida)
    //   - deve ter o campo "subscription" (map)
    //   - endpoint não pode ser vazio nem excessivamente longo
    match /webPushSubscriptions/{subscriptionId} {
      allow read:   if false;
      allow delete: if false;

      allow create, update: if
        // Campos obrigatórios presentes
        request.resource.data.keys().hasAll(['endpoint', 'subscription']) &&
        // endpoint deve ser string com URL HTTPS
        request.resource.data.endpoint is string &&
        request.resource.data.endpoint.size() > 10 &&
        request.resource.data.endpoint.size() <= 2048 &&
        request.resource.data.endpoint.matches('https://.*') &&
        // subscription deve ser um map (objeto)
        request.resource.data.subscription is map &&
        // Documento não pode ter mais de 15 campos
        request.resource.data.keys().size() <= 15;
    }
  }
}
